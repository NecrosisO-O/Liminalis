generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  REGULAR_USER
}

enum AdmissionState {
  PENDING_APPROVAL
  APPROVED
}

enum EnablementState {
  ENABLED
  DISABLED
}

enum DeviceTrustState {
  UNTRUSTED
  TRUSTED
}

enum PairingSessionState {
  AWAITING_PAIR
  AWAITING_APPROVAL
  TRUSTED
  REJECTED
  EXPIRED
}

enum ConfidentialityLevel {
  SECRET
  CONFIDENTIAL
  TOP_SECRET
}

enum UploadContentKind {
  SINGLE_FILE
  GROUPED_CONTENT
  SELF_SPACE_TEXT
}

enum GroupStructureKind {
  MULTI_FILE
  FOLDER
}

enum UploadSessionPhase {
  CREATED
  PREPARING
  UPLOADING
  FINALIZING
  COMPLETED
  ABANDONED
  EXPIRED
  FAILED
}

enum SourceItemState {
  ACTIVE
  INVALIDATED
  EXPIRED
  PURGED
}

enum ProtectedObjectType {
  SOURCE_ITEM
  SHARE_OBJECT
}

enum AccessGrantStatus {
  CURRENT
  SUPERSEDED
}

enum AccessGrantSubjectMode {
  OWNER_DOMAIN
  OWNER_DEVICE_SNAPSHOT
  RECIPIENT_DOMAIN
  RECIPIENT_DEVICE_SNAPSHOT
}

enum PackageFamilyKind {
  OWNER_ORDINARY
  OWNER_RECOVERY
  RECIPIENT_ORDINARY
  RECIPIENT_RECOVERY
}

enum RetrievalFamily {
  SOURCE_ITEM_OWNER
}

enum RetrievalAttemptStatus {
  ISSUED
  IN_PROGRESS
  COMPLETED
  ABANDONED
  FAILED
}

enum ProjectionSourceType {
  SOURCE_ITEM
}

model User {
  id               String           @id @default(cuid())
  username         String           @unique
  email            String?
  passwordHash     String
  role             UserRole         @default(REGULAR_USER)
  admissionState   AdmissionState   @default(PENDING_APPROVAL)
  enablementState  EnablementState  @default(ENABLED)
  approvedAt       DateTime?
  approvedById     String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  sessions         Session[]
  invitesCreated   InviteCode[]     @relation("InvitesCreated")
  devices          TrustedDevice[]
  recoverySet      RecoveryCredentialSet?
  wrappingKeys     UserDomainWrappingKey[]
  uploadSessions   UploadSession[]
  sourceItems      SourceItem[]
  retrievalAttempts RetrievalAttempt[]
  activeTimelineItems ActiveTimelineItemProjection[]
  historyEntries      HistoryEntryProjection[]
  searchDocuments     SearchDocumentProjection[]
}

model InviteCode {
  id           String    @id @default(cuid())
  code         String    @unique
  createdById  String
  createdBy    User      @relation("InvitesCreated", fields: [createdById], references: [id])
  expiresAt    DateTime
  consumedAt   DateTime?
  consumedById String?
  invalidatedAt DateTime?
  createdAt    DateTime  @default(now())
}

model Session {
  id           String    @id @default(cuid())
  token        String    @unique
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  expiresAt    DateTime
  idleExpiresAt DateTime
  lastActivityAt DateTime @default(now())
  createdAt    DateTime  @default(now())
}

model TrustedDevice {
  id                     String                @id @default(cuid())
  userId                 String
  user                   User                  @relation(fields: [userId], references: [id])
  label                  String
  trustState             DeviceTrustState      @default(UNTRUSTED)
  trustEstablishedAt     DateTime?
  publicIdentityVersion  Int                   @default(1)
  publicIdentityPayload  String?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  pairingRequests        PairingSession[]      @relation("PairingRequester")
  approvals              PairingSession[]      @relation("PairingApprover")
  retrievalAttempts      RetrievalAttempt[]
}

model PairingSession {
  id                String              @id @default(cuid())
  state             PairingSessionState @default(AWAITING_PAIR)
  requesterDeviceId String
  requesterDevice   TrustedDevice       @relation("PairingRequester", fields: [requesterDeviceId], references: [id])
  approverDeviceId  String?
  approverDevice    TrustedDevice?      @relation("PairingApprover", fields: [approverDeviceId], references: [id])
  qrToken           String              @unique
  shortCode         String              @unique
  expiresAt         DateTime
  approvedAt        DateTime?
  rejectedAt        DateTime?
  createdAt         DateTime            @default(now())
}

model RecoveryCredentialSet {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id])
  codeHashOne         String
  codeHashTwo         String
  codeHashThree       String
  pendingDisplayBlob  String?
  pendingDisplayUntil DateTime?
  rotatedAt           DateTime?
  acknowledgedAt      DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model UserDomainWrappingKey {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  version    Int
  publicKey  String
  isCurrent  Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@unique([userId, version])
}

model PolicyBundle {
  id                    String               @id @default(cuid())
  levelName             ConfidentialityLevel
  bundleVersion         Int
  isCurrent             Boolean              @default(true)
  updatedByAdminId      String?
  lifecycle             Json
  shareAvailability     Json
  userTargetedSharing   Json
  passwordExtraction    Json
  publicLinks           Json
  liveTransfer          Json
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  uploadSessions        UploadSession[]
  sourceItems           SourceItem[]

  @@unique([levelName, bundleVersion])
}

model UploadSession {
  id                     String              @id @default(cuid())
  uploaderUserId         String
  uploaderUser           User                @relation(fields: [uploaderUserId], references: [id])
  contentKind            UploadContentKind
  groupStructureKind     GroupStructureKind?
  confidentialityLevel   ConfidentialityLevel
  policyBundleId         String
  policyBundle           PolicyBundle        @relation(fields: [policyBundleId], references: [id])
  policySnapshot         Json
  requestedValidityMinutes Int?
  resolvedValidityMinutes  Int?
  burnAfterReadEnabled   Boolean             @default(false)
  phase                  UploadSessionPhase  @default(CREATED)
  expiresAt              DateTime
  finalizedSourceItemId  String?             @unique
  finalizedSourceItem    SourceItem?         @relation("UploadSessionFinalizedSourceItem", fields: [finalizedSourceItemId], references: [id])
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  parts                  UploadPart[]

  @@index([uploaderUserId, phase])
}

model UploadPart {
  id              String        @id @default(cuid())
  uploadSessionId String
  uploadSession   UploadSession @relation(fields: [uploadSessionId], references: [id])
  partNumber      Int
  storageKey      String
  byteSize        Int
  checksum        String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([uploadSessionId, partNumber])
}

model SourceItem {
  id                     String                @id @default(cuid())
  ownerUserId            String
  ownerUser              User                  @relation(fields: [ownerUserId], references: [id])
  contentKind            UploadContentKind
  groupStructureKind     GroupStructureKind?
  confidentialityLevel   ConfidentialityLevel
  state                  SourceItemState       @default(ACTIVE)
  policyBundleId         String
  policyBundle           PolicyBundle          @relation(fields: [policyBundleId], references: [id])
  policySnapshot         Json
  displayName            String?
  textCiphertextBody     String?
  storageBinding         Json?
  validUntil             DateTime?
  burnAfterReadEnabled   Boolean               @default(false)
  uploadSession          UploadSession?        @relation("UploadSessionFinalizedSourceItem")
  groupManifest          GroupManifest?
  accessGrantSets        AccessGrantSet[]
  packageFamilies        PackageFamily[]
  retrievalAttempts      RetrievalAttempt[]
  activeTimelineItem     ActiveTimelineItemProjection?
  historyEntry           HistoryEntryProjection?
  searchDocument         SearchDocumentProjection?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
}

model GroupManifest {
  id                 String             @id @default(cuid())
  sourceItemId       String             @unique
  sourceItem         SourceItem         @relation(fields: [sourceItemId], references: [id])
  structureKind      GroupStructureKind
  manifestJson       Json
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
}

model PackageFamily {
  id                  String              @id @default(cuid())
  protectedObjectType ProtectedObjectType
  protectedObjectId   String
  sourceItemId        String?
  sourceItem          SourceItem?         @relation(fields: [sourceItemId], references: [id])
  kind                PackageFamilyKind
  familyVersion       Int
  issueTrigger        String
  referenceBlob       Json
  createdAt           DateTime            @default(now())
  ordinaryGrantSets   AccessGrantSet[]    @relation("OrdinaryPackageFamily")
  recoveryGrantSets   AccessGrantSet[]    @relation("RecoveryPackageFamily")
  packageReferences   PackageReference[]

  @@index([protectedObjectType, protectedObjectId, kind])
}

model AccessGrantSet {
  id                        String                 @id @default(cuid())
  version                   Int
  protectedObjectType       ProtectedObjectType
  sourceItemId              String?
  sourceItem                SourceItem?            @relation(fields: [sourceItemId], references: [id])
  status                    AccessGrantStatus      @default(CURRENT)
  grantSubjectMode          AccessGrantSubjectMode
  subjectUserId             String
  snapshotDeviceIds         String[]
  ordinaryPackageFamilyId   String
  ordinaryPackageFamily     PackageFamily          @relation("OrdinaryPackageFamily", fields: [ordinaryPackageFamilyId], references: [id])
  recoveryEnabled           Boolean                @default(true)
  recoveryPackageFamilyId   String?
  recoveryPackageFamily     PackageFamily?         @relation("RecoveryPackageFamily", fields: [recoveryPackageFamilyId], references: [id])
  confidentialityLevel      ConfidentialityLevel
  allowFutureTrustedDevices Boolean                @default(false)
  allowRecipientMultiDeviceAccess Boolean          @default(false)
  issueTrigger              String
  supersedesAccessGrantSetId String?
  issuedAt                  DateTime               @default(now())
  supersededAt              DateTime?

  @@unique([sourceItemId, version])
  @@index([protectedObjectType, status])
}

model PackageReference {
  id                      String            @id @default(cuid())
  packageFamilyId         String
  packageFamily           PackageFamily     @relation(fields: [packageFamilyId], references: [id])
  packageFamilyKind       PackageFamilyKind
  protectedObjectType     ProtectedObjectType
  protectedObjectId       String
  eligibleSubjectUserId   String
  eligibleSubjectDeviceId String
  packageFamilyVersion    Int
  wrappedPayloadReference Json
  expiresAt               DateTime
  createdAt               DateTime          @default(now())
  retrievalAttempt        RetrievalAttempt?

  @@index([protectedObjectType, protectedObjectId, packageFamilyKind])
}

model RetrievalAttempt {
  id                 String                 @id @default(cuid())
  retrievalFamily    RetrievalFamily
  targetObjectType   ProtectedObjectType
  targetObjectId     String
  sourceItemId       String?
  sourceItem         SourceItem?            @relation(fields: [sourceItemId], references: [id])
  requestingUserId   String
  requestingUser     User                   @relation(fields: [requestingUserId], references: [id])
  requestingDeviceId String
  requestingDevice   TrustedDevice          @relation(fields: [requestingDeviceId], references: [id])
  status             RetrievalAttemptStatus @default(ISSUED)
  attemptScopeKey    String
  packageReferenceId String?                @unique
  packageReference   PackageReference?      @relation(fields: [packageReferenceId], references: [id])
  issuedAt           DateTime               @default(now())
  completedAt        DateTime?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  @@unique([retrievalFamily, targetObjectId, requestingUserId, requestingDeviceId, attemptScopeKey])
  @@index([sourceItemId, status])
}

model ActiveTimelineItemProjection {
  id                 String               @id @default(cuid())
  ownerUserId        String
  ownerUser          User                 @relation(fields: [ownerUserId], references: [id])
  sourceObjectType   ProjectionSourceType
  sourceObjectId     String
  sourceItemId       String               @unique
  sourceItem         SourceItem           @relation(fields: [sourceItemId], references: [id])
  displayTitle       String?
  visibleTypeLabel   String
  visibleSizeBytes   Int?
  groupedItemCount   Int?
  sourceLabel        String
  activeStatusLabel  String
  confidentialityLevel ConfidentialityLevel
  currentRetrievable Boolean
  visibleSummary     String?
  createdTime        DateTime
  validUntil         DateTime?
  projectedAt        DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@unique([ownerUserId, sourceObjectType, sourceObjectId])
}

model HistoryEntryProjection {
  id                   String               @id @default(cuid())
  ownerUserId          String
  ownerUser            User                 @relation(fields: [ownerUserId], references: [id])
  sourceObjectType     ProjectionSourceType
  sourceObjectId       String
  sourceItemId         String               @unique
  sourceItem           SourceItem           @relation(fields: [sourceItemId], references: [id])
  displayTitle         String?
  visibleTypeLabel     String
  sourceLabel          String
  confidentialityLevel ConfidentialityLevel
  retainedStatus       String
  retrievable          Boolean
  concreteReason       String?
  visibleSummary       String?
  createdTime          DateTime
  statusTime           DateTime?
  projectedAt          DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  @@unique([ownerUserId, sourceObjectType, sourceObjectId])
}

model SearchDocumentProjection {
  id                   String               @id @default(cuid())
  ownerUserId          String
  ownerUser            User                 @relation(fields: [ownerUserId], references: [id])
  sourceObjectType     ProjectionSourceType
  sourceObjectId       String
  sourceItemId         String               @unique
  sourceItem           SourceItem           @relation(fields: [sourceItemId], references: [id])
  displayTitle         String?
  visibleSummary       String?
  sourceLabel          String
  visibleTypeLabel     String
  visibleStatusLabel   String
  confidentialityLevel ConfidentialityLevel
  retrievable          Boolean
  projectedAt          DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  @@unique([ownerUserId, sourceObjectType, sourceObjectId])
}
